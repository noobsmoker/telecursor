{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://telecursor.org/schema/trajectory.schema.json",
  "title": "CursorNet Trajectory Schema",
  "description": "Schema for cursor trajectory data in the TeleCursor research platform",
  "type": "object",
  "required": [
    "session_id",
    "trajectory_id",
    "timestamp",
    "samples"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$",
      "description": "SHA-256 hash of (user_id + session_salt)"
    },
    "trajectory_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique trajectory identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of trajectory start"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 600000,
      "description": "Trajectory duration in milliseconds (max 10 minutes)"
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 60000,
      "description": "Array of cursor samples at 20-50Hz",
      "items": {
        "$ref": "#/definitions/cursor_sample"
      }
    },
    "page_context": {
      "description": "Page context (optional, for grounding models)",
      "type": "object",
      "properties": {
        "url_hash": {
          "type": "string",
          "description": "SHA-256 hash of the page URL"
        },
        "viewport_width": {
          "type": "integer",
          "minimum": 320
        },
        "viewport_height": {
          "type": "integer",
          "minimum": 240
        },
        "dom_path": {
          "type": "string",
          "description": "CSS selector path to element under cursor"
        }
      }
    },
    "privacy": {
      "description": "Privacy metadata",
      "type": "object",
      "required": ["epsilon"],
      "properties": {
        "epsilon": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Differential privacy budget consumed"
        },
        "noise_mechanism": {
          "type": "string",
          "enum": ["none", "laplace", "gaussian"]
        },
        "anonymized": {
          "type": "boolean"
        }
      }
    },
    "consent": {
      "description": "Consent metadata",
      "type": "object",
      "required": ["research_consent"],
      "properties": {
        "research_consent": {
          "type": "boolean"
        },
        "data_usage": {
          "type": "string",
          "enum": ["research_only", "research_and_improvement", "any"]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "annotations": {
      "description": "Optional annotations for training",
      "type": "object",
      "properties": {
        "task_type": {
          "type": "string",
          "enum": ["browse", "search", "form_fill", "click", "scroll", "unknown"]
        },
        "intent": {
          "type": "string"
        },
        "is_bot": {
          "type": "boolean"
        },
        "quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  },
  "definitions": {
    "cursor_sample": {
      "type": "object",
      "required": ["t", "x", "y"],
      "properties": {
        "t": {
          "type": "integer",
          "minimum": 0,
          "description": "Relative timestamp in milliseconds"
        },
        "x": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7680,
          "description": "X coordinate in pixels"
        },
        "y": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4320,
          "description": "Y coordinate in pixels"
        },
        "vx": {
          "type": "number",
          "description": "Velocity X in px/s"
        },
        "vy": {
          "type": "number",
          "description": "Velocity Y in px/s"
        },
        "ax": {
          "type": "number",
          "description": "Acceleration X in px/s²"
        },
        "ay": {
          "type": "number",
          "description": "Acceleration Y in px/s²"
        },
        "button": {
          "type": "integer",
          "enum": [0, 1, 2, 4, 8, 16],
          "description": "Mouse button state bitfield"
        },
        "scroll_dx": {
          "type": "integer",
          "description": "Scroll delta X"
        },
        "scroll_dy": {
          "type": "integer",
          "description": "Scroll delta Y"
        },
        "element_id": {
          "type": "string",
          "description": "Element ID at cursor position"
        },
        "element_tag": {
          "type": "string",
          "description": "HTML tag at cursor position"
        }
      }
    }
  }
}